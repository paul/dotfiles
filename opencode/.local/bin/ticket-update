#!/usr/bin/env bash
# tk-plugin: Update ticket fields from command line
# tk-plugin-version: 1.0.0
set -euo pipefail

# =============================================================================
# Helpers
# =============================================================================

# Portable sed -i (BSD requires -i '', GNU uses -i)
_sed_i() {
    local file="$1"
    shift
    local tmp="${file}.tmp.$$"
    sed "$@" "$file" > "$tmp" && mv "$tmp" "$file"
}

# Resolve ticket file (exact or partial match)
# Same logic as ticket-edit
resolve_ticket() {
    local id="$1"
    read -r id <<< "$id"

    local exact="$TICKETS_DIR/${id}.md"
    if [[ -f "$exact" ]]; then
        echo "$exact"
        return 0
    fi

    local matches count
    matches=$(find "$TICKETS_DIR" -maxdepth 1 -name "*${id}*.md" 2>/dev/null)

    if [[ -z "$matches" ]]; then
        count=0
    else
        count=$(printf '%s\n' "$matches" | wc -l)
    fi

    if [[ "$count" -eq 1 ]]; then
        echo "$matches"
        return 0
    elif [[ "$count" -gt 1 ]]; then
        echo "Error: ambiguous ID '$id' matches multiple tickets" >&2
        return 1
    else
        echo "Error: ticket '$id' not found" >&2
        return 1
    fi
}

# Update or insert a YAML frontmatter field
# Same logic as update_yaml_field in the main ticket script
update_field() {
    local file="$1" field="$2" value="$3"

    if grep -q "^${field}:" "$file"; then
        _sed_i "$file" "s/^${field}:.*/${field}: ${value}/"
    else
        _sed_i "$file" "0,/^---$/ { /^---$/a\\
${field}: ${value}
}"
    fi
}

# Remove a YAML frontmatter field line
remove_field() {
    local file="$1" field="$2"
    _sed_i "$file" "/^${field}:/d"
}

# =============================================================================
# Tag helpers
# =============================================================================

# Read current tags as comma-separated string (no spaces, no brackets)
current_tags() {
    local file="$1"
    local raw
    raw=$(grep "^tags:" "$file" 2>/dev/null | sed 's/^tags: *//; s/^\[//; s/\]$//; s/, */,/g') || true
    echo "$raw"
}

# --tags: replace entire tags field
set_tags() {
    local file="$1" tags="$2"
    update_field "$file" "tags" "[${tags//,/, }]"
}

# --add-tags: merge new tags into existing set (dedup)
add_tags() {
    local file="$1" new_tags="$2"
    local existing
    existing=$(current_tags "$file")

    # Build deduplicated list
    local -A seen=()
    local result=""
    local IFS=','

    for tag in $existing; do
        [[ -z "$tag" ]] && continue
        if [[ -z "${seen[$tag]+x}" ]]; then
            seen[$tag]=1
            result="${result:+$result,}$tag"
        fi
    done

    for tag in $new_tags; do
        [[ -z "$tag" ]] && continue
        if [[ -z "${seen[$tag]+x}" ]]; then
            seen[$tag]=1
            result="${result:+$result,}$tag"
        fi
    done

    if [[ -n "$result" ]]; then
        update_field "$file" "tags" "[${result//,/, }]"
    fi
}

# --remove-tags: remove specific tags, remove field if empty
remove_tags() {
    local file="$1" remove="$2"
    local existing
    existing=$(current_tags "$file")

    # Build set of tags to remove
    local -A to_remove=()
    local IFS=','
    for tag in $remove; do
        [[ -n "$tag" ]] && to_remove[$tag]=1
    done

    # Filter existing tags
    local result=""
    for tag in $existing; do
        [[ -z "$tag" ]] && continue
        if [[ -z "${to_remove[$tag]+x}" ]]; then
            result="${result:+$result,}$tag"
        fi
    done

    if [[ -n "$result" ]]; then
        update_field "$file" "tags" "[${result//,/, }]"
    else
        remove_field "$file" "tags"
    fi
}

# =============================================================================
# Body helpers
# =============================================================================

# Update the title (first `# ` line outside frontmatter)
update_title() {
    local file="$1" new_title="$2"
    local tmp="${file}.tmp.$$"

    awk -v new_title="$new_title" '
        /^---$/ { front = !front }
        !front && !did_title && /^# / {
            print "# " new_title
            did_title = 1
            next
        }
        { print }
    ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# Replace the description (intro text between title and first ## heading)
replace_description() {
    local file="$1" new_desc="$2"
    local tmp="${file}.tmp.$$"

    awk -v new_desc="$new_desc" '
        /^---$/ { front = !front }

        # After frontmatter, find the title line
        !front && !past_title && /^# / {
            print
            past_title = 1
            in_desc = 1
            # Print blank line + new description + blank line
            print ""
            if (new_desc != "") print new_desc
            print ""
            next
        }

        # Skip old description lines until we hit a ## heading or EOF
        in_desc && /^## / {
            in_desc = 0
            print
            next
        }
        in_desc { next }

        { print }
    ' "$file" > "$tmp" && mv "$tmp" "$file"
}

# Replace content of a named ## section, or insert it if missing.
# Content spans from the ## heading to the next ## heading or EOF.
replace_section() {
    local file="$1" heading="$2" new_content="$3"

    if grep -q "^${heading}$" "$file"; then
        # Section exists — replace its content
        local tmp="${file}.tmp.$$"

        awk -v heading="$heading" -v new_content="$new_content" '
            /^---$/ { front = !front }
            !front && $0 == heading {
                print
                print ""
                if (new_content != "") print new_content
                print ""
                skipping = 1
                next
            }
            skipping && /^## / {
                skipping = 0
                print
                next
            }
            !skipping { print }
        ' "$file" > "$tmp" && mv "$tmp" "$file"
    else
        # Section missing — insert at appropriate position
        insert_section "$file" "$heading" "$new_content"
    fi
}

# Insert a new section at the appropriate position in the file.
# Ordering: ## Design < ## Acceptance Criteria < ## Notes < EOF
insert_section() {
    local file="$1" heading="$2" new_content="$3"

    local insert_before=""
    case "$heading" in
        "## Design")
            if grep -q "^## Acceptance Criteria$" "$file"; then
                insert_before="## Acceptance Criteria"
            elif grep -q "^## Notes$" "$file"; then
                insert_before="## Notes"
            fi
            ;;
        "## Acceptance Criteria")
            if grep -q "^## Notes$" "$file"; then
                insert_before="## Notes"
            fi
            ;;
    esac

    if [[ -n "$insert_before" ]]; then
        # Insert before the target heading
        local tmp="${file}.tmp.$$"

        awk -v heading="$heading" -v new_content="$new_content" -v before="$insert_before" '
            $0 == before {
                print heading
                print ""
                if (new_content != "") print new_content
                print ""
                print
                next
            }
            { print }
        ' "$file" > "$tmp" && mv "$tmp" "$file"
    else
        # Append at end of file
        printf '\n%s\n\n%s\n\n' "$heading" "$new_content" >> "$file"
    fi
}

# =============================================================================
# Arg parsing
# =============================================================================

if [[ $# -lt 1 ]]; then
    echo "Usage: tk update <id> [options]" >&2
    echo "" >&2
    echo "Options:" >&2
    echo "  --title <text>          Update title" >&2
    echo "  -d, --description <text> Update description" >&2
    echo "  --design <text>         Update design section" >&2
    echo "  --acceptance <text>     Update acceptance criteria section" >&2
    echo "  -p, --priority <n>      Update priority (0-4)" >&2
    echo "  -t, --type <type>       Update type (bug|feature|task|epic|chore)" >&2
    echo "  -a, --assignee <name>   Update assignee" >&2
    echo "  --external-ref <ref>    Update external reference" >&2
    echo "  --parent <id>           Update parent ticket" >&2
    echo "  --tags <t1,t2>          Replace all tags" >&2
    echo "  --add-tags <t1,t2>      Add tags" >&2
    echo "  --remove-tags <t1,t2>   Remove tags" >&2
    exit 1
fi

id="$1"
shift

title="" description="" design="" acceptance=""
priority="" issue_type="" assignee="" external_ref="" parent=""
tags="" add_tags_val="" remove_tags_val=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --title) title="$2"; shift 2 ;;
        -d|--description) description="$2"; shift 2 ;;
        --design) design="$2"; shift 2 ;;
        --acceptance) acceptance="$2"; shift 2 ;;
        -p|--priority) priority="$2"; shift 2 ;;
        -t|--type) issue_type="$2"; shift 2 ;;
        -a|--assignee) assignee="$2"; shift 2 ;;
        --external-ref) external_ref="$2"; shift 2 ;;
        --parent) parent="$2"; shift 2 ;;
        --tags) tags="$2"; shift 2 ;;
        --add-tags) add_tags_val="$2"; shift 2 ;;
        --remove-tags) remove_tags_val="$2"; shift 2 ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) echo "Unknown argument: $1" >&2; exit 1 ;;
    esac
done

# Validate: --tags is exclusive with --add-tags / --remove-tags
if [[ -n "$tags" && ( -n "$add_tags_val" || -n "$remove_tags_val" ) ]]; then
    echo "Error: --tags cannot be combined with --add-tags or --remove-tags" >&2
    exit 1
fi

# =============================================================================
# Main
# =============================================================================

file=$(resolve_ticket "$id") || exit 1
ticket_id=$(basename "$file" .md)

# --- YAML field updates ---

[[ -n "$priority" ]]     && update_field "$file" "priority" "$priority"
[[ -n "$issue_type" ]]   && update_field "$file" "type" "$issue_type"
[[ -n "$assignee" ]]     && update_field "$file" "assignee" "$assignee"
[[ -n "$external_ref" ]] && update_field "$file" "external-ref" "$external_ref"

if [[ -n "$parent" ]]; then
    # Validate parent exists
    parent_file=$(resolve_ticket "$parent") || exit 1
    resolved_parent=$(basename "$parent_file" .md)
    update_field "$file" "parent" "$resolved_parent"
fi

# --- Tag updates ---

[[ -n "$tags" ]]            && set_tags "$file" "$tags"
[[ -n "$add_tags_val" ]]    && add_tags "$file" "$add_tags_val"
[[ -n "$remove_tags_val" ]] && remove_tags "$file" "$remove_tags_val"

# --- Body updates ---

[[ -n "$title" ]]       && update_title "$file" "$title"
[[ -n "$description" ]] && replace_description "$file" "$description"
[[ -n "$design" ]]      && replace_section "$file" "## Design" "$design"
[[ -n "$acceptance" ]]  && replace_section "$file" "## Acceptance Criteria" "$acceptance"

echo "$ticket_id"
