{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-bell@0.1.0",
    // "opencode-claude-auth",
    // "file:./obsidian-notes",
  ],
  "mcp": {},
  "agent": {
    "build": {
      "model": "openai/gpt-5.4"
    },
    "plan": {
      "model": "openai/gpt-5.4"
    },
    "rubber-ducky": {
      "model": "openai/gpt-5.4"
    },
    "explore": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "title": {
      "model": "openai/gpt-5.3-codex-spark"
    },
    "summary": {
      "model": "openai/gpt-5.3-codex-spark"
    },
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    },
    "standardrb": {
      "disabled": true
    }
  },
  "lsp": {
    "ruby-lsp": {
      "disabled": true
    }
  },
  "permission": {
    "bash": {
      "terraform*": "deny",
      "aws*": "ask",
    },
    "external_directory": {
      "/tmp/**": "allow",
      "/private/tmp/**": "allow",
    }
  }
}
