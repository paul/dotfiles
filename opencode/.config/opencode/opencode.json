{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-bell@0.1.0",
    // "file:./obsidian-notes",
  ],
  "mcp": {},
  "agent": {
    "build": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "plan": {
      "model": "anthropic/claude-opus-4-6"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "title": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "summary": {
      "model": "anthropic/claude-haiku-4-5"
    },
  },
  "formatter": {
    "rubocop": {
      "disabled": true
    },
    "standardrb": {
      "disabled": true
    }
  },
  "lsp": {
    "ruby-lsp": {
      "disabled": true
    }
  },
  "permission": {
    "bash": {
      "terraform*": "deny"
    },
    "external_directory": {
      "/tmp/**": "allow",
    }
  }
}
